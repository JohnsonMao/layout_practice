{
  "name": "@agent-relay/platform-github",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@agent-relay/core": "workspace:*",
    "@octokit/rest": "catalog:prod",
    "@octokit/webhooks": "catalog:prod",
    "dotenv": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "tsup": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
