{
  "name": "@agent-relay/platform-discord",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "deploy-commands": "tsx ./src/deploy-commands.ts",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@agent-relay/core": "workspace:*",
    "discord.js": "catalog:prod",
    "dotenv": "catalog:prod",
    "sql.js": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@types/sql.js": "catalog:dev",
    "tsup": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
