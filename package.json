{
  "name": "agent-relay-root",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test --output-logs=errors-only",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check": "turbo run lint typecheck test --output-logs=errors-only",
    "deploy:discord": "pnpm --filter @agent-relay/platform-discord deploy-commands",
    "typecheck": "turbo run typecheck",
    "dev:desktop": "turbo run dev --filter=desktop",
    "build:desktop": "turbo run build --filter=desktop"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "eslint": "catalog:dev",
    "turbo": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
