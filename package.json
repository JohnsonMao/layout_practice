{
  "name": "agent-relay-root",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test --output-logs=errors-only",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "turbo run build test --output-logs=errors-only",
    "dev:relay": "pnpm --filter relay-service dev",
    "dev:discord": "RELAY_PLATFORMS=discord pnpm --filter relay-service dev",
    "dev:github": "RELAY_PLATFORMS=github pnpm --filter relay-service dev",
    "deploy:discord": "pnpm --filter @agent-relay/platform-discord deploy-commands",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "eslint": "catalog:dev",
    "turbo": "catalog:dev",
    "typescript": "catalog:dev"
  }
}
