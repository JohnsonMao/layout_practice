{
  "name": "relay-service",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@agent-relay/core": "workspace:*",
    "@agent-relay/platform-discord": "workspace:*",
    "@agent-relay/platform-github": "workspace:*",
    "@agent-relay/provider-copilot-sdk": "workspace:*",
    "@agent-relay/provider-cursor-cli": "workspace:*",
    "@agent-relay/provider-gemini": "workspace:*",
    "dotenv": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "tsup": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
