{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": []
    },
    "deploy-commands": {
      "cache": false
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "cache": true
    },
    "tauri:dev": {
      "cache": false,
      "persistent": true
    },
    "tauri:build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "src-tauri/target/release/bundle/**"
      ]
    }
  }
}
