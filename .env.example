# 專案根目錄 .env 範例（複製為 .env 後填寫）
# 供 discord-bot 等從根目錄執行的 script 使用

# Discord Application (Bot)
# 從 Discord Developer Portal → Application → Bot / OAuth2 取得
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# 選填：只註冊到單一伺服器時使用（deploy-commands 會註冊到該 guild）
# 不設則註冊為全球指令（約需 1 小時生效）
# DISCORD_GUILD_ID=your_guild_id_here
