# Example .env at repo root (copy to .env and fill in)
# Used by discord-bot and other scripts run from root

# =============================================================================
# DISCORD
# =============================================================================
# From Discord Developer Portal → Application → Bot / OAuth2
# Enable "MESSAGE CONTENT INTENT" under Bot → Privileged Gateway Intents
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Optional: single-guild registration (deploy-commands registers to this guild)
# Omit to register global commands (may take ~1 hour)
# DISCORD_GUILD_ID=your_guild_id_here

# =============================================================================
# RELAY BACKEND
# =============================================================================
# Who handles AI chat: cursor-cli (default) or copilot-sdk
# RELAY_PROVIDER=cursor-cli

# --- Cursor (when RELAY_PROVIDER=cursor-cli) ---
# Auth: log in with Cursor CLI locally (e.g. run `agent` per docs) OR set CURSOR_API_KEY
# CURSOR_API_KEY=your_cursor_api_key_here
# Optional: model (default Auto)
# CURSOR_MODEL=Auto

# --- Copilot (when RELAY_PROVIDER=copilot-sdk) ---
# Auth: log in with Copilot CLI locally OR set COPILOT_GITHUB_TOKEN / GH_TOKEN / GITHUB_TOKEN
# COPILOT_GITHUB_TOKEN=your_github_token_here
# GH_TOKEN=your_github_token_here
# Optional: default model (default gpt-5)
# COPILOT_DEFAULT_MODEL=gpt-5

# =============================================================================
# WORKSPACE (optional)
# =============================================================================
# Paths for /create-chat. Default is bot cwd if WORKSPACE_DEFAULT not set.
# WORKSPACE_DEFAULT=/path/to/default-project
# WORKSPACE_OTHER_REPO=/path/to/other-repo
# These appear as workspace choices: default, other-repo
