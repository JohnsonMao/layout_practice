# Example .env at repo root (copy to .env and fill in)
# Used by relay-service and other scripts run from root

# =============================================================================
# ORCHESTRATION
# =============================================================================
# Comma-separated list of platforms to enable: discord, github
RELAY_PLATFORMS=discord

# Who handles AI chat: cursor-cli (default), copilot-sdk, gemini
# RELAY_PROVIDER=cursor-cli

# =============================================================================
# PLATFORM: DISCORD
# =============================================================================
# From Discord Developer Portal → Application → Bot / OAuth2
# Enable "MESSAGE CONTENT INTENT" under Bot → Privileged Gateway Intents
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here

# Optional: single-guild registration (deploy-commands registers to this guild)
# DISCORD_GUILD_ID=your_guild_id_here

# =============================================================================
# PLATFORM: GITHUB
# =============================================================================
# Auth: Personal Access Token (classic) with 'repo' and 'discussion' scopes
GITHUB_TOKEN=your_github_token_here
# Webhook: Secret set in GitHub repository settings
WEBHOOK_SECRET=your_webhook_secret_here
# Optional: Webhook server port (default 3000)
# PORT=3000
# Optional: allowed repos comma-separated "owner/repo" (default all)
# GITHUB_BOT_ALLOWED_REPOS=owner/repo
# Optional: per-repo rate limit (default none)
# GITHUB_BOT_RATE_LIMIT_PER_MIN=5

# =============================================================================
# PROVIDER: CURSOR (when RELAY_PROVIDER=cursor-cli)
# =============================================================================
# Auth: login with Cursor CLI locally OR set CURSOR_API_KEY
# CURSOR_API_KEY=your_cursor_api_key_here
# Optional: model (default Auto)
# CURSOR_MODEL=Auto

# =============================================================================
# PROVIDER: COPILOT (when RELAY_PROVIDER=copilot-sdk)
# =============================================================================
# Auth: set COPILOT_GITHUB_TOKEN, GH_TOKEN, or GITHUB_TOKEN
# COPILOT_GITHUB_TOKEN=your_github_token_here
# Optional: default model (default gpt-5)
# COPILOT_DEFAULT_MODEL=gpt-5

# =============================================================================
# PROVIDER: GEMINI (when RELAY_PROVIDER=gemini)
# =============================================================================
# Auth: API Key from Google AI Studio
# GEMINI_API_KEY=your_gemini_api_key_here
# Optional: default model (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
